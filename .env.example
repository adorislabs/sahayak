# Copy this file to .env and fill in your values.
# Never commit .env to git — it is in .gitignore.

# Required: Google Gemini API key (get one at https://aistudio.google.com)
GEMINI_API_KEY=

# Optional: OpenRouter API key (fallback LLM if Gemini quota exceeded)
OPENROUTER_API_KEY=

# Optional: Telegram alerting (fire-and-forget error notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: Override the parsed_schemes directory path
# CBC_RULE_BASE_PATH=parsed_schemes
